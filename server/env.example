# Copy to .env and fill in values (never commit real .env).

# Postgres (Neon): Project → Connection string → paste here
DATABASE_URL=

# Clerk: Dashboard → API Keys (use production keys before real launch)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Google Gemini (AI Studio → Get API key): used for articles, titles, resume review, optional image
GEMINI_API_KEY=

# Primary chat model + fallbacks when you hit RPM / quota (comma-separated)
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MODEL_FALLBACKS=gemini-2.5-flash-lite,gemini-2.0-flash

# Optional: ms to wait before retry after a Gemini 429 (default 6000)
# GEMINI_RATE_LIMIT_WAIT_MS=6000

# Optional: native image API model if you enable billing (image chain still tries Pollinations first)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Clipdrop (optional; paid). Image routes try Pollinations / Gemini before Clipdrop.
CLIPDROP_API_KEY=

# Cloudinary (uploads + AI background/Object removal need a valid Cloudinary account + often paid add-ons)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Danger: drops public.creations once on startup. Only for fixing bad legacy schema.
# FORCE_RECREATE_PUBLIC_CREATIONS=false

PORT=3000
